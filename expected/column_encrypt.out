(1 row)

SELECT cipher_resume_rotation_job(:job_id2) AS resumed;
 resumed 
---------
 t
(1 row)

SELECT status FROM cipher_rotation_progress() WHERE job_id = :job_id2;
 status  
---------
 running
(1 row)

SELECT cipher_cancel_rotation_job(:job_id2) AS cancelled;
 cancelled 
-----------
 t
(1 row)

SELECT status FROM cipher_rotation_progress() WHERE job_id = :job_id2;
  status   
-----------
 cancelled
(1 row)

